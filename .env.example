# =============================================
# VnComplyDemo — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# --- VnComply Environment Configuration ---

# Backend API URL (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Supabase Connection (For future production scaling)
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Node Environment
NODE_ENV=development

# --- JWT (Scanner platform auth — NOT Supabase auth) ---
JWT_SECRET=change_this_to_a_strong_random_secret_in_production

# --- App ---
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
