# =============================================
# VnComplyDemo — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# --- Supabase ---
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI mode)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase REST API (optional — for direct JS client)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- JWT (Scanner platform auth — NOT Supabase auth) ---
JWT_SECRET=change_this_to_a_strong_random_secret_in_production

# --- App ---
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
